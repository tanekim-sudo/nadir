# Database
DATABASE_URL=postgresql://nadir:nadir@localhost:5432/nadir

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# AI
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL_OPUS=claude-opus-4-20250514
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001

# Market data
POLYGON_API_KEY=your_key_here

# Alpaca (paper by default)
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_key_here
ALPACA_LIVE=false

# NextAuth (frontend; also set in frontend/.env.local)
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=http://localhost:3000
GITHUB_ID=your_github_oauth_app_id
GITHUB_SECRET=your_github_oauth_app_secret

# Optional notifications
SLACK_WEBHOOK_URL=
EMAIL_FROM=
EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Internal API URL for Next.js server-side calls
INTERNAL_API_URL=http://localhost:8000
